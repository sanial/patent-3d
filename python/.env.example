# Copy this file to `.env` and fill in your key.
# `.env` is gitignored — never commit real credentials.

# Google AI Studio key (https://aistudio.google.com/app/apikey)
GEMMA_API_KEY=

# Optional overrides
# GEMMA_API_MODEL=gemma-4-27b-it
# GEMMA_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Ollama fallback (used when GEMMA_API_KEY is empty)
# OLLAMA_BASE_URL=http://localhost:11434
# GEMMA_MODEL=gemma4:4b
